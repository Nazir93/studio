# Скопируйте в frontend/.env.production на сервере (Docker).
# База данных не используется.
#
# После правки файла: docker compose up -d --force-recreate nextjs
# Личный чат: сначала напишите боту /start. Группа: chat_id вида -100...

NEXT_PUBLIC_SITE_URL="https://ваш-домен.ru"
NEXT_PUBLIC_SITE_NAME="CODE 1.618"
NEXT_PUBLIC_CITY=""

# Без этих строк заявки с сайта вернут 503 (без Docker: файл должен совпадать с systemd EnvironmentFile)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

NEXT_PUBLIC_YANDEX_METRIKA_ID=""
NEXT_PUBLIC_GA_ID=""
